{
  "name": "uzgidrochat-app",
  "version": "1.0.0",
  "description": "Корпоративный мессенджер для Узбекгидроэнерго",
  "author": "Tim <tim@uzgidro.uz>",
  "main": "electron.js",
  "private": true,
  "packageManager": "npm@11.9.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron": "ng build && electron .",
    "electron-dev": "electron . --dev",
    "dist": "ng build && electron-builder"
  },
  "build": {
    "appId": "uz.uzgidro.chat",
    "productName": "UzGidroChat",
    "directories": {
      "output": "release"
    },
    "files": [
  "dist/**/*",
  "electron.js",
  "package.json",
  "src/assets/**/*"
    ],
    "win": {
  "target": "nsis",
  "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@primeng/themes": "^21.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
